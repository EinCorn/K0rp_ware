{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "K0rp ClickAudit",
  "version": "0.1.0",
  "identifier": "dev.k0rp.clickaudit",
  "build": {
    "beforeDevCommand": "npm run dev:web",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build:web",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "K0rp ClickAudit",
        "width": 300,
        "height": 240,
        "minWidth": 240,
        "minHeight": 180,
        "resizable": false,
        "alwaysOnTop": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "icon": [],
    "category": "Utility",
    "shortDescription": "Local aggregate click counter",
    "longDescription": "Local-only aggregate mouse click counter for K0rp_ware."
  }
}
