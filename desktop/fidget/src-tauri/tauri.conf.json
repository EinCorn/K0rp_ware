{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "K0rp Fidget",
  "version": "0.1.0",
  "identifier": "dev.k0rp.fidget",
  "build": {
    "beforeDevCommand": "npm run dev:web",
    "devUrl": "http://127.0.0.1:1421",
    "beforeBuildCommand": "npm run build:web",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "K0rp Fidget",
        "width": 230,
        "height": 230,
        "minWidth": 230,
        "minHeight": 230,
        "resizable": false,
        "alwaysOnTop": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "icon": ["icons/icon.png"],
    "category": "Utility",
    "shortDescription": "Local fidget spinner toy",
    "longDescription": "Local-only fidget spinner toy for K0rp_ware. No telemetry. No purpose."
  }
}
