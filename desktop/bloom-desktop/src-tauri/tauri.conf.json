{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Toy",
  "version": "0.1.0",
  "identifier": "dev.local.toy",
  "build": {
    "beforeDevCommand": "npm run dev:web",
    "devUrl": "http://127.0.0.1:1422",
    "beforeBuildCommand": "npm run build:web",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Toy",
        "width": 230,
        "height": 230,
        "resizable": false,
        "decorations": true
      }
    ],
    "security": { "csp": null }
  },
  "bundle": { "active": false, "icon": [] }
}
