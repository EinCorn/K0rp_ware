{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "K0rp Bloom",
  "version": "0.3.0",
  "identifier": "dev.local.k0rp-bloom",
  "build": {
    "beforeDevCommand": "npm run dev:web",
    "devUrl": "http://127.0.0.1:1422",
    "beforeBuildCommand": "npm run build:web",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "K0rp Bloom",
        "width": 230,
        "height": 230,
        "minWidth": 230,
        "minHeight": 230,
        "resizable": false,
        "alwaysOnTop": false,
        "decorations": false,
        "transparent": true,
        "shadow": false
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "icon": ["icons/icon.png", "icons/icon.ico"],
    "category": "Utility",
    "shortDescription": "Lokální puzzle se stavovými kameny",
    "longDescription": "Lokální puzzle se stavovými kameny pro K0rp_ware. Bez telemetrie."
  }
}
