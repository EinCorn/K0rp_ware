{
  "name": "k0rp-ware",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:korp-icons": "node scripts/build-k0rp-icons.mjs",
    "build:korp-ui-assets": "node scripts/validate-korp-ui-assets.mjs --write",
    "build:korp-ui-pack-v01": "node scripts/validate-korp-ui-pack-v01.mjs --write",
    "test:korp-icons": "node --test scripts/__tests__/korpIconValidation.test.mjs",
    "test:korp-ui-assets": "node --test scripts/__tests__/korpUiAssetValidation.test.mjs",
    "test:korp-ui-pack-v01": "node --test scripts/__tests__/korpUiPackV01Validation.test.mjs",
    "validate:korp-icons": "node scripts/build-k0rp-icons.mjs --check && npm run test:korp-icons",
    "validate:korp-ui-assets": "node scripts/validate-korp-ui-assets.mjs && npm run test:korp-ui-assets",
    "validate:korp-ui-pack-v01": "node scripts/validate-korp-ui-pack-v01.mjs && npm run test:korp-ui-pack-v01",
    "lint": "eslint .",
    "preview": "vite preview",
    "sync:korp-ui": "node scripts/sync-k0rp-ui.mjs",
    "test:runtime": "node --test src/runtime/__tests__/auditProgression.test.js src/runtime/__tests__/auditFormDraft.test.js src/runtime/__tests__/auditWindowPresentation.test.js src/runtime/__tests__/authorizationPresentation.test.js src/runtime/__tests__/clickAuditActivity.test.js src/runtime/__tests__/clickAuditEvents.test.js src/runtime/__tests__/clickAuditPresentation.test.js src/runtime/__tests__/fidgetEvents.test.js src/runtime/__tests__/fidgetMotion.test.js src/runtime/__tests__/fidgetPresentation.test.js src/runtime/__tests__/fidgetSession.test.js src/runtime/__tests__/korpIconPresentation.test.js src/runtime/__tests__/metricAuditFlow.test.js src/runtime/__tests__/moduleAuthorization.test.js src/runtime/__tests__/moduleWindowPresentation.test.js src/runtime/__tests__/osClickTracking.test.js src/runtime/__tests__/runtimePersistence.test.js src/runtime/__tests__/windowManager.test.js",
    "test:runtime-save": "node --test src/runtime/__tests__/runtimePersistence.test.js",
    "test:korp-core": "npm --prefix packages/korp-core test",
    "typecheck:korp-core": "npm --prefix packages/korp-core run typecheck",
    "test:korp-modules": "npm --prefix packages/korp-modules test",
    "typecheck:korp-modules": "npm --prefix packages/korp-modules run typecheck",
    "typecheck:korp-progression": "npm --prefix packages/korp-progression run typecheck",
    "validate:korp-progression": "npm --prefix packages/korp-progression run validate"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^17.6.0",
    "vite": "^8.1.0"
  }
}
